# ── MemoryOps AI environment ─────────────────────────────────────────────────

# Storage backend for the API: "memory" (no infra) or "postgres"
MEMORYOPS_STORAGE=postgres

# Postgres (used when MEMORYOPS_STORAGE=postgres)
POSTGRES_USER=memoryops
POSTGRES_PASSWORD=memoryops
POSTGRES_DB=memoryops
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://memoryops:memoryops@db:5432/memoryops

# Redis (session/working memory cache; optional in Phase 1)
REDIS_URL=redis://redis:6379/0

# LLM provider adapter. Leave provider=heuristic to run with NO API keys.
# provider options: heuristic | openai | anthropic | gemini
LLM_PROVIDER=heuristic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Embeddings: "heuristic" (deterministic local hash) or "openai"
EMBEDDINGS_PROVIDER=heuristic
EMBEDDING_DIM=1536

# Observability
LOG_LEVEL=INFO
SERVICE_NAME=memoryops-api

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
